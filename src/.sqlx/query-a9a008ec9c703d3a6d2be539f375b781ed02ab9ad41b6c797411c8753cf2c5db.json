  "query": "\nSELECT\n    s.transition_date AS date,\n    s.source AS \"from\",\n    s.destination AS \"to\"\nFROM\n    engine_transitions AS s\nWHERE\n    s.source = $1\n    AND machine_id = $2\nORDER BY\n    s.transition_date DESC\nLIMIT\n    1\n            ",
