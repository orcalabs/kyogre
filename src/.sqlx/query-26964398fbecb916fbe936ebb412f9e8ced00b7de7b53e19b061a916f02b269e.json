  "query": "\nSELECT\n    user_haul_id AS \"id: UserHaulId\",\n    start_ts,\n    end_ts AS \"end_ts!\",\n    start_fuel_liter,\n    end_fuel_liter AS \"end_fuel_liter!\",\n    config\nFROM\n    user_hauls\nWHERE\n    call_sign = $1\n    AND end_ts IS NOT NULL\n    AND end_fuel_liter IS NOT NULL\nORDER BY\n    start_ts\n            ",
